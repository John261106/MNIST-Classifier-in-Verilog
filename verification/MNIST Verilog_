##################################################\n","# CNN MODEL\n","########################################################\n","\n","class MNIST_CNN(nn.Module):\n","\n","    def __init__(self):\n","        super().__init__()\n","\n","        self.conv = nn.Conv2d(\n","            in_channels=1,\n","            out_channels=8,\n","            kernel_size=3,\n","            stride=1,\n","            padding=0\n","        )\n","\n","        self.relu = nn.ReLU()\n","\n","        self.pool = nn.MaxPool2d(\n","            kernel_size=2,\n","            stride=2\n","        )\n","\n","        self.fc = nn.Linear(\n","            13*13*8,\n","            10\n","        )\n","\n","    def forward(self, x):\n","\n","        x = self.conv(x)\n","        x = self.relu(x)\n","        x = self.pool(x)\n","        x = torch.flatten(x,1)\n","        x = self.fc(x)\n","\n","        return x\n","\n","\n","########################################################\n","# LOAD TRAINED MODEL\n","########################################################\n","\n","MODEL_PATH = \"/content/drive/MyDrive/MNIST_Verilog/mnist_cnn.pth\"\n","\n","model = MNIST_CNN()\n","\n","model.load_state_dict(\n","    torch.load(\n","        MODEL_PATH,\n","        map_location=\"cpu\"\n","    )\n",")\n","\n","model.eval()\n","\n","\n","########################################################\n","# GET WEIGHTS\n","########################################################\n","\n","conv_w = model.conv.weight.detach().cpu().numpy()\n","conv_b = model.conv.bias.detach().cpu().numpy()\n","\n","\n","########################################################\n","# QUANTIZATION (Q2.6)\n","########################################################\n","\n","FRAC_BITS = 6\n","SCALE = 1 << FRAC_BITS\n","\n","def quantize(value):\n","\n","    q = int(round(float(value) * SCALE))\n","\n","    if q > 127:\n","        q = 127\n","\n","    if q < -128:\n","        q = -128\n","\n","    return q\n","\n","\n","########################################################\n","# GENERATE VERILOG FILE\n","########################################################\n","\n","OUTPUT_FILE = \"/content/drive/MyDrive/MNIST_Verilog/kernel_init.vh\"\n","\n","with open(OUTPUT_FILE, \"w\") as f:\n","\n","    f.write(\"//=========================================\\n\")\n","    f.write(\"// AUTO GENERATED BY PYTHON\\n\")\n","    f.write(\"// Quantization : Q2.6\\n\")\n","    f.write(\"//=========================================\\n\\n\")\n","\n","    for k in range(8):\n","\n","        f.write(f\"//------------- Kernel {k} -------------\\n\\n\")\n","\n","        for r in range(3):\n","            for c in range(3):\n","\n","                q = quantize(conv_w[k][0][r][c])\n","\n","                f.write(\n","                    f\"kernel[{k}][{r}][{c}] = 8'sd{q};\\n\"\n","                )\n","\n","        bias = int(round(float(conv_b[k]) * SCALE))\n","\n","        f.write(\"\\n\")\n","\n","        f.write(\n","            f\"bias[{k}] = 21'sd{bias};\\n\\n\"\n","        )\n","\n","print(\"=======================================\")\n","print(\"kernel_init.vh generated successfully!\")\n","print(\"Saved at:\")\n","print(OUTPUT_FILE)\n","print(\"=======================================\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Cque_MQ8fe-7","executionInfo":{"status":"ok","timestamp":1783175275330,"user_tz":-330,"elapsed":1578,"user":{"displayName":"John Bobby","userId":"13134439594548151336"}},"outputId":"d46d2934-84ed-4262-8824-fc921832b35b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["=======================================\n","kernel_init.vh generated successfully!\n","Saved at:\n","/content/drive/MyDrive/MNIST_Verilog/kernel_init.vh\n","=======================================\n"]}]},{"cell_type":"code","source":["import torch\n","import torch.nn as nn\n","import os\n","\n","####################################################\n","# SAME MODEL USED FOR TRAINING\n","####################################################\n","\n","class MNIST_CNN(nn.Module):\n","\n","    def __init__(self):\n","        super().__init__()\n","\n","        self.conv = nn.Conv2d(\n","            in_channels=1,\n","            out_channels=8,\n","            kernel_size=3,\n","            stride=1,\n","            padding=0\n","        )\n","\n","        self.relu = nn.ReLU()\n","\n","        self.pool = nn.MaxPool2d(\n","            kernel_size=2,\n","            stride=2\n","        )\n","\n","        self.fc = nn.Linear(\n","            13*13*8,\n","            10\n","        )\n","\n","    def forward(self,x):\n","\n","        x=self.conv(x)\n","        x=self.relu(x)\n","        x=self.pool(x)\n","        x=torch.flatten(x,1)\n","        x=self.fc(x)\n","\n","        return x\n","\n","\n","####################################################\n","# LOAD MODEL\n","####################################################\n","\n","model = MNIST_CNN()\n","\n","model.load_state_dict(\n","    torch.load(\n","        \"/content/drive/MyDrive/MNIST_Verilog/mnist_cnn.pth\",\n","        map_location=\"cpu\"\n","    )\n",")\n","\n","model.eval()\n","\n","####################################################\n","# GET FC PARAMETERS\n","####################################################\n","\n","fc_weight = model.fc.weight.detach().cpu().numpy()\n","fc_bias   = model.fc.bias.detach().cpu().numpy()\n","\n","####################################################\n","# QUANTIZATION\n","####################################################\n","\n","WEIGHT_SCALE = 64      # Q2.6\n","BIAS_SCALE   = 4096    # Q*.12\n","\n","def quantize_weight(x):\n","\n","    q = int(round(float(x) * WEIGHT_SCALE))\n","\n","    q = max(-128, min(127, q))\n","\n","    return q\n","\n","def quantize_bias(x):\n","\n","    return int(round(float(x) * BIAS_SCALE))\n","\n","####################################################\n","# OUTPUT DIRECTORY\n","###########################